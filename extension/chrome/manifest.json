{
  "manifest_version": 3,
  "name": "SyncMark Extension",
  "version": "1.0.0",
  "description": "Sync your bookmarks to a local file.",
  "permissions": ["bookmarks", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
